APP_BASE_URL=http://localhost:8000
CORS_ORIGINS=["*"]

STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=backend/storage_data
STORAGE_LOCAL_MOUNT=/storage

# For S3-compatible storage (used when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_URL_TTL_SECONDS=900

TRYON_MAX_UPLOAD_MB=10

# AI provider: mock | http
AI_PROVIDER=mock
# HTTP inference endpoint that accepts:
# - multipart files: person_image, garment_image
# - form field: category (tops | bottoms | one-pieces)
AI_HTTP_ENDPOINT=
AI_HTTP_TOKEN=
AI_HTTP_TIMEOUT_SECONDS=120
AI_ENSURE_RUNNING_URL=
AI_ENSURE_POLL_SECONDS=5
AI_ENSURE_MAX_WAIT_SECONDS=180
