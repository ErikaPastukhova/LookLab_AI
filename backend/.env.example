APP_BASE_URL=http://localhost:8000
CORS_ORIGINS=["*"]

# Storage for try-on inputs/outputs.
# For local dev keep media locally; catalog JSON is fetched over HTTPS (see catalog vars below).
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=backend/storage_data
STORAGE_LOCAL_MOUNT=/storage

# For S3-compatible storage (used when STORAGE_BACKEND=s3)
S3_BUCKET=onlinemanequine-media
S3_REGION=ru-central1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_URL_TTL_SECONDS=900

# Catalog source (JSON). Loaded at backend startup.
# With STORAGE_BACKEND=local, choose one:
# (A) Yandex path-style: https://storage.yandexcloud.net/{CATALOG_BUCKET}/{CATALOG_OBJECT_KEY}
#     Default bucket name for Looklab prod data:
CATALOG_BUCKET=www.looklab-ai.ru
CATALOG_OBJECT_KEY=catalog/catalog.json
# (B) Or load JSON from your public site root instead of path-style (then bucket is ignored for this fetch):
# CATALOG_HTTP_BASE_URL=https://www.looklab-ai.ru
CATALOG_HTTP_BASE_URL=

TRYON_MAX_UPLOAD_MB=10

# AI provider: mock | http
AI_PROVIDER=http
# HTTP inference endpoint that accepts:
# - multipart files: person_image, garment_image
# - form field: category (tops | bottoms | one-pieces)
# For local dev with cloud inference use an SSH tunnel to the backend VM:
#   ssh -L 8001:10.128.0.20:8001 ubuntu@111.88.254.136
# Then use the local forwarded port below.
AI_HTTP_ENDPOINT=http://127.0.0.1:8001/infer
AI_HTTP_TOKEN=
AI_HTTP_TIMEOUT_SECONDS=300
AI_ENSURE_RUNNING_URL=https://d5dnmn8hm7jc5rsrfis2.nkhmighe.apigw.yandexcloud.net/gpu/ensure_running
AI_ENSURE_POLL_SECONDS=5
AI_ENSURE_MAX_WAIT_SECONDS=240
